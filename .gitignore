__pycache__/
*.py[cod]
.venv/
venv/
.env
.claude/

# All pipeline artifacts (raw, features, derived manifests, splits, backups).
# Nothing under data/ is tracked; if you ever want a small tracked file here,
# add an explicit "!data/<name>" re-include below.
data/
models/checkpoints/
runs/
release/

*.pt
*.pth
*.ckpt
.DS_Store

# Local assistant/operator context. Keep repo docs intentional and public-facing.
/claude.md
/CLAUDE.md
/codex.md
/workflow.md
# Re-include the public project memory at repo root. The /CLAUDE.md line above
# is there for case-insensitive filesystems where /claude.md would otherwise
# match it; this re-include keeps the public memory file tracked.
!/CLAUDE.md
prompts/
superpowers/
docs/prompts/
docs/superpowers/
docs/presentation-guide.md
# Retired LaTeX workspace; keep the report deliverable under report/.
latex/
report/acoustic_probe*/

# LaTeX build artifacts
latex/**/*.aux
latex/**/*.log
latex/**/*.out
latex/**/*.toc
latex/**/*.pdf
latex/**/*.fls
latex/**/*.fdb_latexmk
latex/**/*.synctex.gz
